NODE_ENV=development
# Local-only: mini app + smoke script can authenticate without real MAX initData
DEV_MAX_AUTH_BYPASS=false
# Local-only: bot skips real MAX API on /internal/sync-button (development + this flag)
BOT_MOCK_MAX_API=false
# API behind Nginx / TLS terminator (X-Forwarded-Proto, etc.)
TRUST_PROXY=false
# Admin cookie SameSite override: lax | strict (optional)
# ADMIN_COOKIE_SAME_SITE=strict
# PostgreSQL — database name in the path must exist before API / `pnpm db:deploy`.
# Docker Compose in this repo: `docker compose up -d` creates DB `comments` (see docker-compose.yml).
# From the host (published port 5432):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/comments?schema=public
# From another container on the same Compose network (hostname = service/container name):
#   DATABASE_URL=postgresql://postgres:postgres@comments-db:5432/comments?schema=public
# POSTGRES_DB runs CREATE DATABASE only on first init of an empty volume; it does not fix a missing DB later.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/comments?schema=public
# DB preflight before API bind (see DEPLOYMENT.md): full | wait | off (default full)
# DB_PREFLIGHT_MODE=wait
# Optional: URL for preflight only if app user cannot CONNECT to database "postgres"
# DATABASE_PREFLIGHT_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres?schema=public
# Legacy: skip all preflight (not for production)
# SKIP_DB_PREFLIGHT=true
API_PORT=3001
BOT_PORT=3002
BOT_INTERNAL_BASE_URL=http://localhost:3002
# Bot → API (register). In Docker use service URL, e.g. http://api:3001 — not localhost unless same network namespace.
# API_INTERNAL_BASE_URL=http://api:3001
MINIAPP_PORT=3003
ADMIN_PORT=3004

# Same value is used by the bot and by the API to verify mini app `window.WebApp.initData` (MAX WebAppData HMAC).
MAX_BOT_TOKEN=replace_me
# MAX Bot HTTP API (dev.max.ru): https://platform-api.max.ru — NOT Telegram-style /bot<token>/… on api.max.ru (404 HTML).
MAX_API_BASE_URL=https://platform-api.max.ru
# Optional; sent as query param `v` (official clients use e.g. 1.2.5).
# MAX_API_VERSION=1.2.5
MAX_WEBHOOK_SECRET=replace_me
# Public HTTPS URL of the bot route POST /webhook/max (for `pnpm webhook:subscribe` — not the mini app URL).
# MAX_WEBHOOK_URL=https://commentbot.example.com/webhook/max
# CLI-only: `ENV_FILE=/path/to/.env.production pnpm webhook:list` loads a single file (same as PM2 --env-file).
# Mini app URL used for `link` button mode and web app origin diagnostics.
MAX_WEBAPP_URL=https://example.com/miniapp
# Registered mini app identifier (bot username / link id) used for `open_app.web_app`.
MAX_OPEN_APP_ID=id782576604170_2_bot
# Optional MAX bot contact id for open_app button payload (can be omitted).
# MAX_OPEN_APP_CONTACT_ID=247954163
# Diagnostic: discuss button mode for publish + sync-button — open_app (default) or link (plain url button to same MAX_WEBAPP_URL). See docs/max-open-app-debug.md
# MAX_OPEN_APP_DEBUG_MODE=link

MAX_COMMENT_LENGTH=2000
MAX_ATTACHMENTS_PER_COMMENT=4
MAX_IMAGE_SIZE_MB=10
COMMENT_EDIT_WINDOW_MINUTES=0
USER_CAN_DELETE_OWN_COMMENT=true

COMMENT_COOLDOWN_SECONDS=10
COMMENT_RATE_LIMIT_WINDOW_SECONDS=60
COMMENT_RATE_LIMIT_MAX=5

UPLOAD_DIR=./uploads
# Public base for stored filenames: trailing slashes are stripped; result is `${base}/${filename}`.
# Examples: https://api.example.com/uploads  or  https://api.example.com/prefix/uploads  (no trailing slash).
UPLOAD_PUBLIC_BASE_URL=http://localhost:3001/uploads
ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp

ADMIN_SESSION_SECRET=replace_me
ADMIN_SESSION_TTL_SECONDS=86400
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
