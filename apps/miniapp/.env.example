# Copy to apps/miniapp/.env for local Vite dev
VITE_API_BASE_URL=http://localhost:3001
# When true, mini app uses POST /api/auth/max/init { devMock } instead of real MAX initData
# Requires API NODE_ENV=development and DEV_MAX_AUTH_BYPASS=true in apps/api/.env
VITE_DEV_MAX_AUTH=false
VITE_DEV_MAX_USER_ID=900001
VITE_DEV_CHAT_MAX_ID=-100
# Optional: open http://localhost:3003/?postId=<uuid> when not using WebApp start_param
VITE_DEV_POST_ID=
