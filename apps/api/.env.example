# Copy to `.env` in this directory (or use repo root `.env.example` for the full monorepo template).
#
# The database in DATABASE_URL must exist before `pnpm db:deploy` / API start.
# The API runs a preflight (unless SKIP_DB_PREFLIGHT=true): waits for PostgreSQL and checks pg_database.
#
# --- Typical URLs ---
# Host / IDE against docker-compose (published port 5432):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/comments?schema=public
# Another container on the same Docker network as `comments-db`:
#   DATABASE_URL=postgresql://postgres:postgres@comments-db:5432/comments?schema=public
#
# Legacy local name (still valid if you created that DB):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/max_comment_bot?schema=public
#
# SKIP_DB_PREFLIGHT=true   # legacy: skip preflight (not for production)
# DB_PREFLIGHT_MODE=full   # full | wait | off — default full; wait = TCP only, no pg_database check
# DATABASE_PREFLIGHT_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres?schema=public
#
# Full API env (MAX_BOT_TOKEN for mini app initData validation, upload URLs, admin session, etc.) lives in the
# monorepo root `.env.example` — copy that file or merge vars into `apps/api/.env`.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/comments?schema=public
